#!/usr/bin/env bash
set -euo pipefail

name="metatate"
account_url=""
app_name="METATATE_APP"
schema_name="CORE"
server_name="METATATE_MCP"
auth_mode="pat"
snowflake_role=""
pat_token_env="METATATE_CORTEX_PAT"
client_id=""
client_name="Metatate Cortex Code"
redirect_port="8585"
authorization_server_url=""
oauth_scopes=""
config_file="${HOME}/.snowflake/cortex/mcp.json"
write_config="false"

usage() {
  cat <<'EOF'
Usage:
  metatate-cortex-mcp-add --account-url https://<account-url> --snowflake-role <role> [options]
  metatate-cortex-mcp-add --auth oauth --account-url https://<account-url> --client-id <client-id> --snowflake-role <role> [options]

Options:
  --name <name>                    Cortex MCP server name. Default: metatate
  --account-url <url>              Snowflake account URL, for example https://org-account.snowflakecomputing.com
  --app <app>                      Snowflake application database. Default: METATATE_APP
  --schema <schema>                MCP server schema. Default: CORE
  --server <server>                MCP server name. Default: METATATE_MCP
  --auth <pat|oauth>               Authentication mode. Default: pat
  --snowflake-role <role>          Snowflake role used for MCP calls
  --pat-token-env <env-var>        Env var containing the Snowflake PAT. Default: METATATE_CORTEX_PAT
  --client-id <client-id>          Snowflake OAuth client ID. Required only with --auth oauth
  --client-name <client-name>      OAuth client name shown by Cortex Code. Default: Metatate Cortex Code
  --redirect-port <port>           OAuth loopback redirect port. Default: 8585
  --authorization-server-url <url> Optional OAuth authorization server base URL
  --oauth-scopes <scopes>          Raw OAuth scopes. Overrides --snowflake-role in OAuth mode
  --config-file <path>             Cortex MCP config path. Default: ~/.snowflake/cortex/mcp.json
  --write                          Merge the server into the Cortex MCP config file
  --dry-run                        Print the server JSON without writing. Default behavior
  -h, --help                       Show this help

The default PAT mode writes an Authorization header that references an
environment variable. It does not write the PAT secret into mcp.json.

OAuth mode is available for environments where the Snowflake-managed MCP
protected-resource metadata allows the role-specific scope you need.
EOF
}

while [[ $# -gt 0 ]]; do
  case "$1" in
    --name)
      name="${2:?missing value for --name}"
      shift 2
      ;;
    --account-url)
      account_url="${2:?missing value for --account-url}"
      shift 2
      ;;
    --app)
      app_name="${2:?missing value for --app}"
      shift 2
      ;;
    --schema)
      schema_name="${2:?missing value for --schema}"
      shift 2
      ;;
    --server)
      server_name="${2:?missing value for --server}"
      shift 2
      ;;
    --auth)
      auth_mode="${2:?missing value for --auth}"
      shift 2
      ;;
    --snowflake-role)
      snowflake_role="${2:?missing value for --snowflake-role}"
      oauth_scopes="session:role:${snowflake_role}"
      shift 2
      ;;
    --pat-token-env)
      pat_token_env="${2:?missing value for --pat-token-env}"
      shift 2
      ;;
    --client-id)
      client_id="${2:?missing value for --client-id}"
      shift 2
      ;;
    --client-name)
      client_name="${2:?missing value for --client-name}"
      shift 2
      ;;
    --redirect-port)
      redirect_port="${2:?missing value for --redirect-port}"
      shift 2
      ;;
    --authorization-server-url)
      authorization_server_url="${2:?missing value for --authorization-server-url}"
      shift 2
      ;;
    --oauth-scopes)
      oauth_scopes="${2:?missing value for --oauth-scopes}"
      shift 2
      ;;
    --config-file)
      config_file="${2:?missing value for --config-file}"
      shift 2
      ;;
    --write)
      write_config="true"
      shift
      ;;
    --dry-run)
      write_config="false"
      shift
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    *)
      echo "Unknown argument: $1" >&2
      usage >&2
      exit 2
      ;;
  esac
done

if [[ -z "${account_url}" ]]; then
  usage >&2
  exit 2
fi

account_url="${account_url%/}"
endpoint="${account_url}/api/v2/databases/${app_name}/schemas/${schema_name}/mcp-servers/${server_name}"

case "${auth_mode}" in
  pat)
    if [[ -z "${snowflake_role}" ]]; then
      echo "Missing --snowflake-role for PAT mode." >&2
      exit 2
    fi
    if [[ ! "${pat_token_env}" =~ ^[A-Za-z_][A-Za-z0-9_]*$ ]]; then
      echo "--pat-token-env must be a valid environment variable name." >&2
      exit 2
    fi
    server_json="$(
      ENDPOINT="${endpoint}" \
      SNOWFLAKE_ROLE="${snowflake_role}" \
      PAT_TOKEN_ENV="${pat_token_env}" \
      python3 -c 'import json, os
pat_ref = "${" + os.environ["PAT_TOKEN_ENV"] + "}"
print(json.dumps({
    "type": "http",
    "url": os.environ["ENDPOINT"],
    "headers": {
        "Authorization": "Bearer " + pat_ref,
        "X-Snowflake-Authorization-Token-Type": "PROGRAMMATIC_ACCESS_TOKEN",
        "X-Snowflake-Role": os.environ["SNOWFLAKE_ROLE"],
    },
}, indent=2, sort_keys=True))'
    )"
    ;;
  oauth)
    if [[ -z "${client_id}" ]]; then
      echo "Missing --client-id for OAuth mode." >&2
      exit 2
    fi
    if [[ -z "${oauth_scopes}" ]]; then
      echo "Missing --snowflake-role or --oauth-scopes for OAuth mode." >&2
      exit 2
    fi
    server_json="$(
      ENDPOINT="${endpoint}" \
      CLIENT_ID="${client_id}" \
      CLIENT_NAME="${client_name}" \
      REDIRECT_PORT="${redirect_port}" \
      OAUTH_SCOPES="${oauth_scopes}" \
      AUTHORIZATION_SERVER_URL="${authorization_server_url}" \
      python3 -c 'import json, os
oauth = {
    "client_id": os.environ["CLIENT_ID"],
    "client_name": os.environ["CLIENT_NAME"],
    "redirect_port": int(os.environ["REDIRECT_PORT"]),
    "scope": os.environ["OAUTH_SCOPES"],
}
authorization_server_url = os.environ.get("AUTHORIZATION_SERVER_URL", "")
if authorization_server_url:
    oauth["authorization_server_url"] = authorization_server_url.rstrip("/")
print(json.dumps({
    "type": "http",
    "url": os.environ["ENDPOINT"],
    "oauth": oauth,
}, indent=2, sort_keys=True))'
    )"
    ;;
  *)
    echo "--auth must be either 'pat' or 'oauth'." >&2
    exit 2
    ;;
esac

if [[ "${write_config}" != "true" ]]; then
  printf '%s\n' "${server_json}"
  exit 0
fi

CONFIG_FILE="${config_file}" \
SERVER_NAME="${name}" \
SERVER_JSON="${server_json}" \
python3 -c 'import json, os, pathlib, tempfile
config_path = pathlib.Path(os.environ["CONFIG_FILE"]).expanduser()
server_name = os.environ["SERVER_NAME"]
server = json.loads(os.environ["SERVER_JSON"])
config_path.parent.mkdir(parents=True, exist_ok=True)

if config_path.exists() and config_path.stat().st_size > 0:
    with config_path.open("r", encoding="utf-8") as handle:
        config = json.load(handle)
else:
    config = {}

if not isinstance(config, dict):
    raise SystemExit(f"{config_path} must contain a JSON object")

mcp_servers = config.setdefault("mcpServers", {})
if not isinstance(mcp_servers, dict):
    raise SystemExit(f"{config_path} has invalid mcpServers; expected a JSON object")

mcp_servers[server_name] = server

with tempfile.NamedTemporaryFile("w", encoding="utf-8", dir=str(config_path.parent), delete=False) as handle:
    json.dump(config, handle, indent=2, sort_keys=True)
    handle.write("\n")
    temp_name = handle.name

pathlib.Path(temp_name).replace(config_path)
'

printf 'Wrote Cortex MCP server "%s" to %s\n' "${name}" "${config_file}"
if [[ "${auth_mode}" == "pat" ]]; then
  printf 'Export %s before running Cortex Code or "cortex mcp start".\n' "${pat_token_env}"
else
  printf 'Run "cortex mcp start" to authenticate and connect.\n'
fi
